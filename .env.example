# Локальные настройки проекта. Скопируйте файл в .env и заполните значения.
# .env НЕ нужно отправлять в Git и выкладывать вместе с проектом.

# ----------------------------------------------------------------------------
# Основные настройки Django
# ----------------------------------------------------------------------------
DEBUG=True
SECRET_KEY=replace-this-with-a-random-secret-key
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
ADMIN_URL=admin/
TIME_ZONE=UTC
PASSWORD_MIN_LENGTH=8

# ----------------------------------------------------------------------------
# База данных PostgreSQL
# ----------------------------------------------------------------------------
DB_ENGINE=django.db.backends.postgresql
DB_NAME=project_nankuev_new
DB_USER=postgres
DB_PASSWORD=admin
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=0

# ----------------------------------------------------------------------------
# Защита cookies/HTTPS
# Для локального запуска оставьте False. На сервере с HTTPS поставьте True.
# ----------------------------------------------------------------------------
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
USE_X_FORWARDED_PROTO=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
CSRF_COOKIE_HTTPONLY=True

# ----------------------------------------------------------------------------
# Ограничения загрузки файлов
# ----------------------------------------------------------------------------
DATA_UPLOAD_MAX_MEMORY_SIZE=2621440
FILE_UPLOAD_MAX_MEMORY_SIZE=2621440
DATA_UPLOAD_MAX_NUMBER_FIELDS=1000

# ----------------------------------------------------------------------------
# CDEK
# ----------------------------------------------------------------------------
CDEK_DEMO_MODE=True
CDEK_BASE_URL=https://api.edu.cdek.ru/v2
CDEK_CLIENT_ID=
CDEK_CLIENT_SECRET=
CDEK_FROM_CITY_CODE=44
CDEK_DEFAULT_TARIFF_CODE=137
CDEK_DEFAULT_WEIGHT_GRAMS=300
CDEK_DEFAULT_PACKAGE_LENGTH_CM=30
CDEK_DEFAULT_PACKAGE_WIDTH_CM=20
CDEK_DEFAULT_PACKAGE_HEIGHT_CM=10
CDEK_REQUEST_TIMEOUT=20

# ----------------------------------------------------------------------------
# ЮKassa
# ----------------------------------------------------------------------------
YOOKASSA_DEMO_MODE=True
YOOKASSA_API_URL=https://api.yookassa.ru/v3
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_BASE_URL=http://127.0.0.1:8000
YOOKASSA_CURRENCY=RUB
YOOKASSA_CAPTURE=True
YOOKASSA_REQUEST_TIMEOUT=20

# ----------------------------------------------------------------------------
# Email
# Если логин/пароль пустые, письма выводятся в консоль.
# ----------------------------------------------------------------------------
EMAIL_HOST=smtp.yandex.ru
EMAIL_PORT=465
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=no-reply@example.local
SITE_URL=http://127.0.0.1:8000
EMAIL_NOTIFICATIONS_ENABLED=True

# ----------------------------------------------------------------------------
# Резервирование товаров
# ----------------------------------------------------------------------------
RESERVATION_HOLD_MINUTES=30
